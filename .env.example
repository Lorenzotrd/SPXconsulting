# Public origin used for canonical URLs and OG metadata.
# In production, set this to your real domain (e.g. https://spxconsulting.be).
NEXT_PUBLIC_WEBAPP_URL=http://localhost:3002

# Contact email shown in the hero, contact section, and JSON-LD schema.
NEXT_PUBLIC_CONTACT_EMAIL=hello@spxconsulting.example

# External booking link (Calendly, Cal.com, SavvyCal, etc.).
# Falls back to "#contact" (in-page anchor) if not set.
NEXT_PUBLIC_CALENDAR_URL=https://cal.com/your-handle/intro
